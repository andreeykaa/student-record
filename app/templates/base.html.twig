<!DOCTYPE html>
<html lang="uk" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Student Record{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 64 64%22><text y=%221em%22 font-size=%2252%22>🎓</text></svg>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">

    {% block stylesheets %}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">
{% set currentRoute = app.request.attributes.get('_route') %}
{% set isAdmin = is_granted('ROLE_ADMIN') %}

<div class="app-shell">
    {% block nav %}
        <nav class="navbar navbar-expand-lg sticky-top app-navbar">
            <div class="container">

                {% if currentRoute == 'home' %}
                    <span class="navbar-brand d-flex align-items-center gap-2 app-brand mb-0">
                        <span class="app-brand-badge">🎓</span>
                        <span>Student Record</span>
                    </span>
                {% else %}
                    <a class="navbar-brand d-flex align-items-center gap-2 app-brand" href="{{ path('home') }}">
                        <span class="app-brand-badge">🎓</span>
                        <span>Student Record</span>
                    </a>
                {% endif %}

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    {% if app.user %}
                        {% set navItems = [
                            {
                                label: 'Головна',
                                route: 'home',
                                match: 'home',
                                exact: true,
                                admin: false
                            },
                            {
                                label: 'Учні',
                                route: 'app_student_index',
                                match: 'app_student_',
                                exact: false,
                                admin: true
                            },
                            {
                                label: 'Заняття',
                                route: 'app_lesson_index',
                                match: 'app_lesson_',
                                exact: false,
                                admin: true
                            },
                            {
                                label: 'Користувачі',
                                route: 'app_user_index',
                                match: 'app_user_',
                                exact: false,
                                admin: true
                            }
                        ] %}

                        {% if isAdmin %}
                            <form class="student-navbar-search me-lg-4 mb-3 mb-lg-0" role="search" autocomplete="off">
                                <div class="student-navbar-search-control">
                                    <input
                                        id="studentSearchInput"
                                        class="student-navbar-search-input"
                                        type="text" name="q" placeholder="Пошук" aria-label="Пошук"
                                        data-search-url="{{ path('app_student_search_ajax') }}">

                                    <span class="student-navbar-search-icon">
                                        <i class="bi bi-search"></i>
                                    </span>
                                </div>

                                <div id="studentSearchResults" class="student-navbar-search-results d-none"></div>
                            </form>
                        {% endif %}

                        <ul class="navbar-nav me-auto mb-3 mb-lg-0">
                            {% for item in navItems %}
                                {% set canShow = not item.admin or isAdmin %}

                                {% if canShow %}
                                    {% set isActive = item.exact
                                        ? currentRoute == item.match
                                        : currentRoute starts with item.match
                                    %}

                                    <li class="nav-item">
                                        {% if isActive %}
                                            <span class="nav-link active text-primary fw-semibold" aria-current="page">
                                                {{ item.label }}
                                            </span>
                                        {% else %}
                                            <a class="nav-link" href="{{ path(item.route) }}">
                                                {{ item.label }}
                                            </a>
                                        {% endif %}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <span class="text-secondary small d-none d-md-inline">
                                <i class="bi bi-person-circle me-1"></i>
                                {% if app.user.student %}
                                    {% set titleName = app.user.student.lastName ~ ' ' ~ app.user.student.firstName %}
                                {% else %}
                                    {% set titleName = app.user.userIdentifier %}
                                {% endif %}
                                <strong class="text-primary">{{ titleName }}</strong>
                            </span>

                            <a href="{{ path('app_logout') }}" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-box-arrow-right"></i>
                                Вийти
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </nav>
    {% endblock %}

    <main class="app-main">
        <div class="container">
            {% block page_header %}{% endblock %}

            {% set flashTypes = {
                success: 'success',
                error: 'danger',
                warning: 'warning',
                info: 'info'
            } %}

            <div class="flash-stack mb-4">
                {% for type, bootstrapType in flashTypes %}
                    {% for message in app.flashes(type) %}
                        <div class="alert alert-{{ bootstrapType }} alert-dismissible fade show shadow-sm mb-0" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}

        </div>
    </main>

    <footer class="app-footer py-4 mt-auto">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <small>© {{ "now"|date("Y") }} Student Record</small>

            <small class="d-flex align-items-center gap-1 text-secondary">
                <i class="bi bi-code-slash"></i>
                <span>by Matviichuk Andrii</span>
            </small>
        </div>
    </footer>
</div>

<script src="{{ asset('js/jquery.min.js') }}"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('js/base.js') }}"></script>


{% block javascripts %}{% endblock %}
</body>
</html>
