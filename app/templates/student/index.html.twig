{% extends 'base.html.twig' %}

{% block title %}Список учнів{% endblock %}

{% block page_header %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 fw-bold mb-1">Список учнів</h1>
        </div>

        <a href="{{ path('app_student_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>
            Додати учня
        </a>
    </div>
{% endblock %}

{% block body %}
    <div class="app-card-soft p-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                <tr>
                    <th>Ім'я</th>
                    <th>Прізвище</th>
                    <th>Клас / курс</th>
                    <th>Статус учня</th>
                    <th>Кількість занять</th>
                    <th class="text-center">Дії</th>
                </tr>
                </thead>
                <tbody>
                {% for student in students %}
                    <tr>
                        <td>{{ student.firstName }}</td>
                        <td>{{ student.lastName }}</td>
                        <td>{{ student.schoolGrade }}</td>
                        <td>{{ student.isActive }}</td>
                        <td>{{ student.lessonsCount }}</td>
                        <td class="text-center">
                            <div class="d-inline-flex gap-2">
                                <a href="{{ path('app_student_show', {'id': student.id}) }}"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Переглянути">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a href="{{ path('app_student_edit', {'id': student.id}) }}"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Редагувати">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                {{ include('student/_delete_form.html.twig', {
                                    'student': student,
                                    'button_label': '<i class="bi bi-trash"></i>',
                                    'button_class': 'btn btn-sm btn-outline-danger'
                                }) }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-4">
                            Учні поки що не додані.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {{ include('student/_delete_modal.html.twig') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/student/student.js') }}"></script>
{% endblock %}
