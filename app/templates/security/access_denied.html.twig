{% extends 'base.html.twig' %}

{% block title %}Доступ заборонено{% endblock %}

{% block page_header %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">

    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/security/security.css') }}">
{% endblock %}

{% block body %}
    {% set currentRoute = app.request.attributes.get('_route') %}

    <div class="app-card-soft p-4 p-lg-5 text-center access-denied-card">
        <div class="access-denied-icon">
            <i class="bi bi-shield-lock"></i>
        </div>

        <div class="access-denied-title">Доступ заборонено</div>

        <p class="access-denied-text mb-4">
            Якщо, Ви вважаєте, що трапилась помилка - зверніться до адміністратора!
        </p>

        {% if currentRoute != 'home' %}
            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a href="{{ path('home') }}" class="btn btn-primary">
                    <i class="bi bi-house-door me-1"></i>
                    На головну
                </a>
            </div>
        {% endif %}
    </div>
{% endblock %}
